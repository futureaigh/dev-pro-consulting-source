  <body>
    <div id="root"></div>
    <script type="module" src="https://adaptive.ai/cdn/NIfC4qYvo4JnxcYDsCz_JZga77c.js"></script>

    
<style>
.__watermark_container * {
  font-family: -apple-system,
               BlinkMacSystemFont,
               "Segoe UI",
               Roboto,
               Oxygen,
               Ubuntu,
               Cantarell,
               "Helvetica Neue",
               Arial,
               sans-serif !important;
}

.__watermark_container {
  position: fixed;
  bottom: 15px;
  right: 15px;
  z-index: 9999;
  -webkit-user-select: none;
  user-select: none;
  transition: all 0.3s ease;
  opacity: 1;
  transform-origin: center bottom;
}

.__watermark_container.dismissing {
  opacity: 0;
  transform: translateY(20px);
}

.__watermark_button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  border: 1px solid rgb(226, 232, 240);
  background-image: linear-gradient(to top, rgb(255, 255, 255), rgb(241, 245, 249));
  color: rgba(2, 8, 23, 0.5);
  padding: 8px 8px;
  border-radius: 12px;
  transition: all 0.3s ease;
  height: 36px;
  -webkit-user-select: none;
  user-select: none;
  cursor: pointer;
}

.__watermark_button:hover {
  color: rgba(2, 8, 23, 0.7);
  transform: translateY(-1px);
  box-shadow: 0 2px 8px 0 rgb(0 0 0 / 0.1), 0 2px 4px -1px rgb(0 0 0 / 0.1);
}

.__watermark_close_button {
  opacity: 0;  /* Hidden by default on desktop */
  position: absolute;
  left: 0;
  top: 0;
  transform: translate(-40%, -40%);
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgb(255, 255, 255);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  color: rgb(100, 116, 139);
  font-size: 16px;
  padding: 0;
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
}

/* Show on hover for desktop */
.__watermark_container:hover .__watermark_close_button {
  opacity: 1;
}

/* Always show on mobile */
@media (max-width: 768px) {
  .__watermark_close_button {
    opacity: 1;
  }
}

.__watermark_span {
  display: flex;
  align-items: center;
  font-size: 12px;
  font-weight: 500;
  line-height: 20px;
  word-spacing: 0px;
  gap: 3px;
  -webkit-user-select: none;
  user-select: none;
}

.__watermark_span img {
  display: inline-block;
  -webkit-user-select: none;
  user-select: none;
}

@media (prefers-color-scheme: dark) {
  .__watermark_button {
    border: 1px solid rgb(30, 41, 59);
    background-image: linear-gradient(to top, rgb(2, 8, 23), rgb(30, 41, 59));
    color: rgba(255, 255, 255, 0.7);
  }

  .__watermark_button:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .__watermark_close_button {
    background: hsl(217.2, 32.6%, 17.5%);
    color: rgb(226, 232, 240);
  }

  .__watermark_close_button:hover {
    background: hsl(217.2, 32.6%, 21.5%);
    color: rgb(248, 250, 252);
  }
}
</style>

<div class="__watermark_container" id="watermark-container">
  <a class="__watermark_button" href="https://adaptive.ai" target="_blank" rel="noopener noreferrer">
    <span class="__watermark_span">
      Powered by
      <img alt="Adaptive" height="16" src="/assets/logo.webp" width="16">
      Adaptive
    </span>
    
    <button
      class="__watermark_close_button"
      onclick="event.preventDefault(); event.stopPropagation(); const container = this.parentElement.parentElement; container.classList.add('dismissing'); localStorage.setItem('adaptive-watermark-dismissed-' + window.__APP_ID__, 'true'); setTimeout(() => container.remove(), 300);"
      aria-label="Dismiss watermark"
    >
      <svg width="8" height="8" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1.70711 0.292893C1.31658 -0.0976311 0.683417 -0.0976311 0.292893 0.292893C-0.0976311 0.683417 -0.0976311 1.31658 0.292893 1.70711L3.58579 5L0.292893 8.29289C-0.0976311 8.68342 -0.0976311 9.31658 0.292893 9.70711C0.683417 10.0976 1.31658 10.0976 1.70711 9.70711L5 6.41421L8.29289 9.70711C8.68342 10.0976 9.31658 10.0976 9.70711 9.70711C10.0976 9.31658 10.0976 8.68342 9.70711 8.29289L6.41421 5L9.70711 1.70711C10.0976 1.31658 10.0976 0.683417 9.70711 0.292893C9.31658 -0.0976311 8.68342 -0.0976311 8.29289 0.292893L5 3.58579L1.70711 0.292893Z" fill="currentColor"/>
      </svg>
    </button>
  </a>
</div>

<script>
(function() {
  // Check if watermark was dismissed
  if (localStorage.getItem('adaptive-watermark-dismissed-' + window.__APP_ID__) === 'true') {
    const container = document.getElementById('watermark-container');
    container.style.display = 'none';
  }
})();
</script>

    
    <script>
      mixpanel.init("82af7ae09ec18611ca840273f6863e5c");
      
      mixpanel.track("$mp_web_page_view", {
        isGuestApp: "true",
        isCustomDomain: "false",
        versionId: "VNHKNaHiHCrA3zh8",
        subdomain: "dev-pro-rdu4vujb",
        current_domain: "dev-pro-rdu4vujb.adaptive.ai",
      });

      document.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
          event.preventDefault();
          window.parent.postMessage({ type: 'toggleGoonbarVisibility', source: 'iframe' }, '*');
        } else if (event.key === 'Escape') {
          // escape to minimize
          event.preventDefault();
          window.parent.postMessage({ type: 'minimize', source: 'iframe' }, '*');
        }
      }, true);
      window.addEventListener('message', (event) => {
        if (!event.data || typeof event.data !== 'object') return;
        if (event.data.type === 'setTheme') {
          const theme = event.data.payload?.theme;
          if (theme === 'dark' || theme === 'light') {
            document.documentElement.classList.remove('dark', 'light');
            document.documentElement.classList.add(theme);
          }
        }

        if (event.data.type === 'clearWatermarkDismissal') {
          localStorage.removeItem('adaptive-watermark-dismissed-' + window.__APP_ID__);
          window.location.reload();
        }

        if (event.data.type === 'closeAuthDrawer') {
          const container = document.querySelector('.__drawer_container');
          const frame = document.getElementById('__AUTH_DRAWER');
          const close = document.querySelector('.__auth_close_button');
          container?.classList.add('__hidden');
          frame?.classList.add('__hidden');
          close?.classList.add('__hidden');
        }
      });
    </script>
    
    
<style>
.__drawer_container {
  position: fixed;
  pointer-events: auto !important;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(16px);
  z-index: 10000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: backdrop-filter 1s ease;
}

.__drawer_container.__hidden {
  visibility: hidden;
  pointer-events: none !important;
  backdrop-filter: blur(0);
}

.__auth_close_button {
  position: absolute;
  top: 16px;
  right: 16px;
  cursor: pointer;
  width: 24px;
  height: 24px;
  background: rgb(0, 0, 0, 0.8);
  border: none;
  mask: url(https://static.acflare.com/x.svg) no-repeat center;
  mask-size: contain;
  transition: opacity 0.3s ease;
}

.__auth_close_button:hover {
  background: rgb(0, 0, 0, 1);
}

@media (prefers-color-scheme: dark) {
  .__drawer_container {
    background: rgba(0, 0, 0, 0.4);
  }

  .__auth_close_button {
    background: rgb(255, 255, 255, 0.8);
  }

  .__auth_close_button:hover {
    background: rgb(255, 255, 255, 1);
  }
}

.__drawer_frame {
  width: 100%;
  height: 100%;
  max-width: 400px;
  max-height: 340px;
  border: none;
  border-radius: 16px;
  box-shadow: 0 0 16px rgba(0, 0, 0, 0.1);
  opacity: 1;
  transition: opacity 0.3s ease;
}

.__drawer_frame.__hidden {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}

@media (max-width: 640px) {
  .__drawer_container {
    justify-content: flex-end;
  }

  .__drawer_frame {
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
    max-width: 100%;
  }
}
</style>

<div class="__drawer_container __hidden">
  <iframe
    class="__drawer_frame __hidden"
    id="__AUTH_DRAWER"
    allow="fullscreen; camera; microphone; gyroscope; accelerometer; clipboard-write; clipboard-read; autoplay; geolocation; display-capture; picture-in-picture; payment; midi; bluetooth; web-share; screen-wake-lock; xr-spatial-tracking; encrypted-media; idle-detection; hid; serial; window-management"
    loading="eager"
    referrerPolicy="unsafe-url"
    title="Login">
  </iframe>
  <div alt="Close" class="__auth_close_button"></div>
</div>

<script>
(function() {
  const container = document.querySelector('.__drawer_container');
  const close = document.querySelector('.__auth_close_button');
  function closeFrame() {
    container.classList.add('__hidden');
    const frame = document.getElementById('__AUTH_DRAWER');
    frame.classList.add('__hidden');
  }
  close.addEventListener('click', closeFrame);
  container.addEventListener('click', closeFrame);

})();

window.__OPEN_AUTH_DRAWER__ = (url) => {
  const frame = document.getElementById('__AUTH_DRAWER');
  const container = document.querySelector('.__drawer_container');
  const close = document.querySelector('.__auth_close_button');
  if (container.classList.contains('__hidden')) {
    container.classList.remove('__hidden');
    frame.src = url;
    frame.onload = () => {
      close.classList.remove('__hidden');
      frame.classList.remove('__hidden');
      frame.contentWindow.focus();
    };
  }
}
</script>

  </body>
</html>